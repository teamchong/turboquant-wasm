{
  "name": "turboquant-demos",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "encode:3dgs": "bun run encoder/cli.ts",
    "prepare:embed": "node --experimental-specifier-resolution=node prepare/embed.mjs",
    "prepare:compress": "bun run prepare/compress.ts",
    "prepare:wiki-50k": "node --experimental-specifier-resolution=node prepare/embed.mjs --count 50000 --out public/data/wiki-50k && bun run prepare/compress.ts --dir public/data/wiki-50k"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.1",
    "@mkkellogg/gaussian-splats-3d": "^0.4.7",
    "three": "^0.170.0",
    "turboquant-wasm": "^0.3.0",
    "vectorjson": "^0.5.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/three": "^0.170.0",
    "@webgpu/types": "^0.1.69",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  }
}
