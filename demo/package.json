{
  "name": "turboquant-demos",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "encode:3dgs": "bun run encoder/cli.ts",
    "prepare:embed": "node --experimental-specifier-resolution=node prepare/embed.mjs",
    "prepare:compress": "bun run prepare/compress.ts",
    "prepare:wiki-50k": "node --experimental-specifier-resolution=node prepare/embed.mjs --count 50000 --out public/data/wiki-50k && bun run prepare/compress.ts --dir public/data/wiki-50k",
    "rebuild-cache": "npx playwright test tests/build-cache.spec.ts --timeout=600000 ; node scripts/write-prompt-hash.mjs",
    "write-prompt-hash": "node scripts/write-prompt-hash.mjs"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.0",
    "@excalidraw/excalidraw": "^0.18.0",
    "@huggingface/transformers": "^4.0.1",
    "@mkkellogg/gaussian-splats-3d": "^0.4.7",
    "morphdom": "^2.7.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.170.0",
    "turboquant-wasm": "^0.4.0",
    "vectorjson": "^0.5.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.170.0",
    "@webgpu/types": "^0.1.69",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  }
}
